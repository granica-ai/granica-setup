{
  "Version": "2012-10-17",
  "Statement": [

    {
      "Sid": "CloudShell",
      "Effect": "Allow",
      "Action": ["cloudshell:*"],
      "Resource": "*"
    },
    {
      "Sid": "STS",
      "Effect": "Allow",
      "Action": ["sts:GetCallerIdentity"],
      "Resource": "*"
    },
    {
      "Sid": "TerraformStateS3",
      "Effect": "Allow",
      "Action": [
        "s3:CreateBucket",
        "s3:DeleteBucket",
        "s3:GetBucketLocation",
        "s3:ListBucket",
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": [
        "arn:aws:s3:::granica-vpc-tf-*",
        "arn:aws:s3:::granica-vpc-tf-*/*"
      ]
    },

    {
      "Sid": "IAMProjectNAdmin",
      "Effect": "Allow",
      "Action": [
        "iam:AddRoleToInstanceProfile",
        "iam:AttachRolePolicy",
        "iam:CreateInstanceProfile",
        "iam:CreatePolicy",
        "iam:CreatePolicyVersion",
        "iam:CreateRole",
        "iam:DeleteInstanceProfile",
        "iam:DeletePolicy",
        "iam:DeletePolicyVersion",
        "iam:DeleteRole",
        "iam:DeleteRolePolicy",
        "iam:DetachRolePolicy",
        "iam:GetInstanceProfile",
        "iam:GetPolicy",
        "iam:GetPolicyVersion",
        "iam:GetRole",
        "iam:GetRolePolicy",
        "iam:ListAttachedRolePolicies",
        "iam:ListInstanceProfilesForRole",
        "iam:ListPolicyVersions",
        "iam:ListRolePolicies",
        "iam:PutRolePolicy",
        "iam:RemoveRoleFromInstanceProfile",
        "iam:TagInstanceProfile",
        "iam:TagPolicy",
        "iam:TagRole",
        "iam:UntagInstanceProfile",
        "iam:UntagPolicy",
        "iam:UntagRole",
        "iam:UpdateAssumeRolePolicy"
      ],
      "Resource": [
        "arn:aws:iam::ACCOUNT_ID:role/project-n-admin-*",
        "arn:aws:iam::ACCOUNT_ID:policy/project-n-admin-*",
        "arn:aws:iam::ACCOUNT_ID:instance-profile/project-n-admin-*"
      ]
    },
    {
      "Sid": "IAMListInstanceProfiles",
      "Effect": "Allow",
      "Action": ["iam:ListInstanceProfiles"],
      "Resource": "*"
    },
    {
      "Sid": "IAMPassRoleEC2",
      "Effect": "Allow",
      "Action": ["iam:PassRole"],
      "Resource": "arn:aws:iam::ACCOUNT_ID:role/project-n-admin-*",
      "Condition": {
        "StringEquals": { "iam:PassedToService": "ec2.amazonaws.com" }
      }
    },
    {
      "Sid": "IAMAttachSSMCoreToAdminRole",
      "Effect": "Allow",
      "Action": ["iam:AttachRolePolicy", "iam:DetachRolePolicy"],
      "Resource": [
        "arn:aws:iam::ACCOUNT_ID:role/project-n-admin-*",
        "arn:aws:iam::aws:policy/AmazonSSMManagedInstanceCore"
      ]
    },

    {
      "Sid": "SSMStartSessionTaggedInstance",
      "Effect": "Allow",
      "Action": ["ssm:StartSession", "ssm:SendCommand"],
      "Resource": "arn:aws:ec2:*:ACCOUNT_ID:instance/*",
      "Condition": {
        "StringLike": {
          "ssm:resourceTag/admin_server_name": "granica-admin-server-*"
        }
      }
    },
    {
      "Sid": "SSMStartSessionDocument",
      "Effect": "Allow",
      "Action": ["ssm:StartSession", "ssm:SendCommand"],
      "Resource": "arn:aws:ssm:*:*:document/SSM-SessionManagerRunShell"
    },
    {
      "Sid": "SSMDescribe",
      "Effect": "Allow",
      "Action": [
        "ssm:GetConnectionStatus",
        "ssm:DescribeInstanceInformation",
        "ssm:DescribeInstanceProperties"
      ],
      "Resource": "*"
    },
    {
      "Sid": "SSMSessionOwn",
      "Effect": "Allow",
      "Action": ["ssm:TerminateSession", "ssm:ResumeSession"],
      "Resource": "arn:aws:ssm:*:ACCOUNT_ID:session/${aws:userid}-*"
    },

    {
      "Sid": "EC2Describe",
      "Effect": "Allow",
      "Action": ["ec2:Describe*"],
      "Resource": "*"
    },
    {
      "Sid": "EC2CreateSecurityGroupVpcAndSg",
      "Effect": "Allow",
      "Action": "ec2:CreateSecurityGroup",
      "Resource": [
        "arn:aws:ec2:*:ACCOUNT_ID:vpc/*",
        "arn:aws:ec2:*:ACCOUNT_ID:security-group/*"
      ]
    },
    {
      "Sid": "EC2SecurityGroupMutateAccount",
      "Effect": "Allow",
      "Action": [
        "ec2:AuthorizeSecurityGroupEgress",
        "ec2:AuthorizeSecurityGroupIngress",
        "ec2:CreateTags",
        "ec2:DeleteSecurityGroup",
        "ec2:DeleteTags",
        "ec2:RevokeSecurityGroupEgress",
        "ec2:RevokeSecurityGroupIngress"
      ],
      "Resource": "arn:aws:ec2:*:ACCOUNT_ID:security-group/*"
    },
    {
      "Sid": "EC2InstanceConnectEndpoint",
      "Effect": "Allow",
      "Action": [
        "ec2:CreateInstanceConnectEndpoint",
        "ec2:DeleteInstanceConnectEndpoint",
        "ec2:ModifyInstanceConnectEndpoint"
      ],
      "Resource": [
        "arn:aws:ec2:*:ACCOUNT_ID:subnet/*",
        "arn:aws:ec2:*:ACCOUNT_ID:security-group/*",
        "arn:aws:ec2:*:ACCOUNT_ID:instance-connect-endpoint/*"
      ]
    },
    {
      "Sid": "EC2InstanceConnectEndpointTags",
      "Effect": "Allow",
      "Action": ["ec2:CreateTags", "ec2:DeleteTags"],
      "Resource": "arn:aws:ec2:*:ACCOUNT_ID:instance-connect-endpoint/*"
    },
    {
      "Sid": "EC2CreateTagsRequestAdmin",
      "Effect": "Allow",
      "Action": "ec2:CreateTags",
      "Resource": "*",
      "Condition": {
        "StringLike": {
          "aws:RequestTag/admin_server_name": "granica-admin-server-*"
        }
      }
    },
    {
      "Sid": "EC2CreateTagsResourceAdmin",
      "Effect": "Allow",
      "Action": "ec2:CreateTags",
      "Resource": "*",
      "Condition": {
        "StringLike": {
          "ec2:ResourceTag/admin_server_name": "granica-admin-server-*"
        }
      }
    },
    {
      "Sid": "EC2DeleteTagsResourceAdmin",
      "Effect": "Allow",
      "Action": "ec2:DeleteTags",
      "Resource": "*",
      "Condition": {
        "StringLike": {
          "ec2:ResourceTag/admin_server_name": "granica-admin-server-*"
        }
      }
    },
    {
      "Sid": "EC2RunInstancesSupport",
      "Effect": "Allow",
      "Action": "ec2:RunInstances",
      "Resource": [
        "arn:aws:ec2:*:ACCOUNT_ID:subnet/*",
        "arn:aws:ec2:*:ACCOUNT_ID:network-interface/*",
        "arn:aws:ec2:*:ACCOUNT_ID:volume/*",
        "arn:aws:ec2:*:ACCOUNT_ID:security-group/*",
        "arn:aws:ec2:*::image/*",
        "arn:aws:ec2:*::snapshot/*"
      ]
    },
    {
      "Sid": "EC2RunInstancesTaggedInstance",
      "Effect": "Allow",
      "Action": "ec2:RunInstances",
      "Resource": "arn:aws:ec2:*:ACCOUNT_ID:instance/*",
      "Condition": {
        "StringLike": {
          "aws:RequestTag/admin_server_name": "granica-admin-server-*"
        },
        "StringEquals": { "aws:RequestTag/imds": "secure" }
      }
    },
    {
      "Sid": "EC2TerminateTaggedInstance",
      "Effect": "Allow",
      "Action": "ec2:TerminateInstances",
      "Resource": "*",
      "Condition": {
        "StringLike": {
          "ec2:ResourceTag/admin_server_name": "granica-admin-server-*"
        },
        "StringEquals": { "ec2:ResourceTag/imds": "secure" }
      }
    }

  ]
}
